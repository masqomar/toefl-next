generator client {
  provider = "prisma-client"
  output   = "../lib/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  USER
  ADMIN
  SUPER_ADMIN
}

enum ExamType {
  FREE
  PAID
}

enum PaymentStatus {
  PENDING
  PAID
  FAILED
  EXPIRED
}

enum AccessType {
  FREE
  PAYMENT
  VOUCHER
  ADMIN_GRANT
}

enum SessionStatus {
  IN_PROGRESS
  FINISHED
  AUTO_SUBMITTED
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at       Int?
  token_type       String?
  scope            String?
  id_token         String?  @db.Text
  session_state    String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  password      String?
  role          Role      @default(USER)
  accounts      Account[]
  sessions      Session[]
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

    orders       Order[]
  accesses      ExamAccess[]
  examSessions ExamSession[]
  redemptions  VoucherRedemption[]
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Exam {
  id            String   @id @default(cuid())
  title         String
  description   String?
  thumbnail     String?
  type          ExamType
  price         Float    @default(0)
  status        Boolean  @default(true)
  maxViolations Int      @default(5)
  maxAudioReplay Int     @default(2)
  createdAt     DateTime @default(now())

  sections     ExamSection[]
  orderItems   OrderItem[]
  vouchers     Voucher[]
  accesses     ExamAccess[]
  examSessions ExamSession[]
}

model ExamSection {
  id          String   @id @default(cuid())
  examId      String
  title       String
  sectionType String
  duration    Int
  orderNumber Int

  exam        Exam @relation(fields: [examId], references: [id])
  questions   QuestionBank[]
}

model QuestionBank {
  id            String   @id @default(cuid())
  sectionId      String
  questionNumber Int
  questionText   String
  passageText    String?
  audioUrl       String?
  optionA        String
  optionB        String
  optionC        String
  optionD        String
  correctAnswer  String
  explanation    String?

  section        ExamSection @relation(fields: [sectionId], references: [id])
  answers        UserAnswer[]
}

model Order {
  id                  String   @id @default(cuid())
  userId              String
  invoiceNumber       String   @unique
  totalAmount         Float
  paymentMethod       String?
  paymentGateway      String?
  paymentStatus       PaymentStatus @default(PENDING)
  gatewayTransactionId String?
  createdAt           DateTime @default(now())
  paidAt              DateTime?

  user                User @relation(fields: [userId], references: [id])
  items               OrderItem[]
}

model OrderItem {
  id      String @id @default(cuid())
  orderId String
  examId  String
  price   Float

  order   Order @relation(fields: [orderId], references: [id])
  exam    Exam  @relation(fields: [examId], references: [id])
}

model Voucher {
  id            String   @id @default(cuid())
  code          String   @unique
  title         String
  examId        String
  maxUsage      Int
  usedCount     Int      @default(0)
  isActive      Boolean  @default(true)
  expiredAt     DateTime?

  exam          Exam @relation(fields: [examId], references: [id])
  redemptions   VoucherRedemption[]
}

model VoucherRedemption {
  id         String   @id @default(cuid())
  voucherId   String
  userId      String
  redeemedAt  DateTime @default(now())

  voucher     Voucher @relation(fields: [voucherId], references: [id])
  user        User @relation(fields: [userId], references: [id])
}

model ExamAccess {
  id         String   @id @default(cuid())
  userId      String
  examId      String
  accessType  AccessType
  sourceId    String?
  isActive    Boolean @default(true)
  grantedAt   DateTime @default(now())
  expiredAt   DateTime?

  user        User @relation(fields: [userId], references: [id])
  exam        Exam @relation(fields: [examId], references: [id])
}

model ExamSession {
  id            String   @id @default(cuid())
  userId         String
  examId         String
  startedAt      DateTime @default(now())
  submittedAt    DateTime?
  currentSection Int      @default(1)
  status         SessionStatus @default(IN_PROGRESS)
  violationCount Int      @default(0)

  user           User @relation(fields: [userId], references: [id])
  exam           Exam @relation(fields: [examId], references: [id])
  answers        UserAnswer[]
  result         Result?
}

model UserAnswer {
  id            String   @id @default(cuid())
  sessionId      String
  questionId     String
  selectedAnswer String?
  answeredAt     DateTime @default(now())

  session        ExamSession @relation(fields: [sessionId], references: [id])
  question       QuestionBank @relation(fields: [questionId], references: [id])
}

model Result {
  id               String   @id @default(cuid())
  sessionId         String   @unique
  listeningRaw      Int
  structureRaw      Int
  readingRaw        Int
  listeningScaled   Int
  structureScaled   Int
  readingScaled     Int
  totalScore        Int
  level             String

  session           ExamSession @relation(fields: [sessionId], references: [id])
}